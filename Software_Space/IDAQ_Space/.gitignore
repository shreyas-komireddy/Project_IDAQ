# ============================================================
# Vitis 2024.x Unified IDE - Workspace .gitignore
# ============================================================

# ---- Entire Platform (fully regenerated from .xsa) ----
IDAQ_Pltfrm/export/
IDAQ_Pltfrm/hw/sdt/
IDAQ_Pltfrm/ps7_cortexa9_0/
IDAQ_Pltfrm/resources/
IDAQ_Pltfrm/zynq_fsbl/
IDAQ_Pltfrm/vitis-comp.json

# ---- Platform metadata that has absolute paths ----
IDAQ_Pltfrm/.analytics/
IDAQ_Pltfrm/*.log

# ---- Hello_World build outputs ----
IDAQ_DRVR/build/
IDAQ_DRVR/_ide/
IDAQ_DRVR/compile_commands.json
IDAQ_DRVR/vitis-comp.json
IDAQ_DRVR/src/.cache/


# ---- IDE compile index (machine specific) ----
**/src/.compile_commands/

# ---- Inside src/ - generated files ----
**/src/.clangd
**/src/app.yaml
**/src/compile_commands.json
**/src/*Example.cmake
**/src/UserConfig.cmake
**/src/platform.c
**/src/.compile_commands/
**/src/lscript.ld
**/src/CMakeLists.txt


# ---- Workspace level garbage ----
_ide/
.rigel_lopper/
.analytics/
.vscode/

# ---- Vitis workspace state ----
.vitisWorkspace.json
*.lock
*.log
*.jou
*.str

# ---- Binary outputs ----
*.elf
*.bit
*.bin
*.pdi
*.ltx
*.xclbin

# ---- OS junk ----
.DS_Store
Thumbs.db