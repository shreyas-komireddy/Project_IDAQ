# ============================================================
# Vitis 2024.x Unified IDE - Workspace .gitignore
# ============================================================

# ---- Entire Platform (fully regenerated from .xsa) ----
TMP451_SYS_Pltfrm/export/
TMP451_SYS_Pltfrm/hw/sdt/
TMP451_SYS_Pltfrm/ps7_cortexa9_0/
TMP451_SYS_Pltfrm/resources/
TMP451_SYS_Pltfrm/zynq_fsbl/
TMP451_SYS_Pltfrm/vitis-comp.json

# ---- Platform metadata that has absolute paths ----
TMP451_SYS_Pltfrm/.analytics/
TMP451_SYS_Pltfrm/*.log

# ---- Hello_World build outputs ----
TMP451_DRVR/build/
TMP451_DRVR/_ide/
TMP451_DRVR/compile_commands.json
TMP451_DRVR/vitis-comp.json
TMP451_DRVR/src/.cache/


# ---- IDE compile index (machine specific) ----
**/src/.compile_commands/

# ---- Inside src/ - generated files ----
**/src/.clangd
**/src/app.yaml
**/src/compile_commands.json
**/src/*Example.cmake
**/src/UserConfig.cmake
**/src/platform.c
**/src/.compile_commands/
**/src/lscript.ld
**/src/CMakeLists.txt


# ---- Workspace level garbage ----
_ide/
.rigel_lopper/
.analytics/
.vscode/

# ---- Vitis workspace state ----
.vitisWorkspace.json
*.lock
*.log
*.jou
*.str

# ---- Binary outputs ----
*.elf
*.bit
*.bin
*.pdi
*.ltx
*.xclbin

# ---- OS junk ----
.DS_Store
Thumbs.db